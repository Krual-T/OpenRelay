# Required
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Common runtime defaults
PORT=3000
DATA_DIR=./data
WORKSPACE_ROOT=~
WORKSPACE_DEFAULT_DIR=~/Projects
MAIN_WORKSPACE_DIR=~/Projects
DEVELOP_WORKSPACE_DIR=~/Projects

# Feishu delivery
FEISHU_CONNECTION_MODE=websocket
FEISHU_STREAM_MODE=card
FEISHU_BOT_OPEN_ID=
FEISHU_GROUP_REPLY_ALL=false
FEISHU_GROUP_SESSION_SCOPE=sender
FEISHU_ALLOWED_OPEN_IDS=
FEISHU_ADMIN_OPEN_IDS=

# Optional for webhook or encrypted callbacks
WEBHOOK_PATH=/feishu/webhook
FEISHU_VERIFY_TOKEN=
FEISHU_ENCRYPT_KEY=

# Request limits
MAX_REQUEST_BYTES=1048576
MAX_SESSION_MESSAGES=20

# Backend defaults
DEFAULT_BACKEND=codex
DEFAULT_MODEL=
DEFAULT_SAFETY_MODE=danger-full-access
CODEX_CLI_PATH=codex
CODEX_SQLITE_HOME=./data/codex-sqlite
CODEX_REQUEST_TIMEOUT_SECONDS=

# Optional fixed shortcuts as JSON array
DIRECTORY_SHORTCUTS=
